generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  CASHIER
  VENTA_APOYO
  BODEGA
  COCINA
}

enum BusinessPlan {
  FREE
  BASIC
  PRO
  STARTER
  BUSINESS
  PREMIUM
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum BusinessType {
  COMMERCE
  RESTAURANT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingPaymentMethod {
  PAGO_MOVIL
  ZELLE
  PAYPAL
  BINANCE
  BANK_TRANSFER
  CASH
}

enum SaleCurrency {
  USD
  BS
}

enum PaymentMethod {
  CASH_USD
  CASH_BS
  MOBILE_PAYMENT
  BANK_TRANSFER
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SALE
  EXPENSE
  INCOME
  OPENING
  CLOSING
}

enum ProductUnit {
  UNIT
  KG
  GR
  LT
  ML
  MT
}

enum TransferStatus {
  PENDING
  APPROVED
  SHIPPED
  RECEIVED
  CANCELLED
}

enum PreSaleStatus {
  OPEN
  PAID
  CANCELLED
}

enum KdsStatus {
  PENDING
  PREPARING
  READY
}

enum PublicOrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum FulfillmentMethod {
  DELIVERY
  PICKUP
  DINE_IN
}

model Business {
  id                   String                    @id @default(cuid())
  name                 String
  slug                 String                    @unique
  email                String?
  phone                String?
  ownerFirstName       String?
  ownerLastName        String?
  address              String?
  city                 String?
  country              String?
  businessType         BusinessType              @default(COMMERCE)
  currency             String                    @default("USD")
  exchangeRate         Decimal                   @default(1) @db.Decimal(12, 4)
  plan                 BusinessPlan              @default(STARTER)
  planId               String?
  subscriptionPlan     Plan?                     @relation(fields: [planId], references: [id], onDelete: SetNull)
  status               BusinessStatus            @default(ACTIVE)
  trialStart           DateTime                  @default(now())
  trialEnd             DateTime                  @default(dbgenerated("(now() + interval '30 days')"))
  subscriptionStatus   SubscriptionStatus        @default(TRIAL)
  nextPaymentAt        DateTime?
  lastPaymentAt        DateTime?
  billingPaymentMethod BillingPaymentMethod?
  users                User[]
  categories           Category[]
  products             Product[]
  sales                Sale[]
  expenses             Expense[]
  customers            Customer[]
  cashSessions         CashSession[]
  cashMovements        CashMovement[]
  branches             Branch[]
  branchInventories    BranchInventory[]
  stockTransfers       StockTransfer[]
  preSales             PreSale[]
  hardwareSettings     BusinessHardwareSettings?
  publicSettings       BusinessPublicSettings?
  publicOrders         PublicOrder[]
  accessRoles          AccessRole[]
  auditLogs            AuditLog[]
  productHistory       ProductHistory[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([planId])
}

model Plan {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  priceMonthly Decimal    @db.Decimal(12, 2)
  priceYearly  Decimal    @db.Decimal(12, 2)
  maxUsers     Int
  maxBranches  Int
  trialAllowed Boolean    @default(true)
  status       String     @default("ACTIVE")
  features     Json       @default("[]")
  businesses   Business[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model BusinessPublicSettings {
  id              String   @id @default(cuid())
  businessId      String   @unique
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  coverImageUrl   String?
  logoUrl         String?
  rating          Decimal  @default(4.8) @db.Decimal(3, 2)
  distanceLabel   String   @default("0.8 km")
  etaLabel        String   @default("25-35 min")
  deliveryEnabled Boolean  @default(true)
  pickupEnabled   Boolean  @default(true)
  dineInEnabled   Boolean  @default(false)
  openTime        String   @default("09:00")
  closeTime       String   @default("21:00")
  activeDays      String   @default("1,2,3,4,5,6")
  deliveryFee     Decimal  @default(0) @db.Decimal(12, 2)
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  termsUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PublicOrder {
  id                String            @id @default(cuid())
  businessId        String
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code              String
  status            PublicOrderStatus @default(NEW)
  fulfillmentMethod FulfillmentMethod
  customerName      String
  customerPhone     String
  address           String?
  addressReference  String?
  lat               Decimal?          @db.Decimal(10, 7)
  lng               Decimal?          @db.Decimal(10, 7)
  notes             String?
  paymentMethod     String
  subtotal          Decimal           @db.Decimal(12, 2)
  deliveryFee       Decimal           @default(0) @db.Decimal(12, 2)
  tax               Decimal           @default(0) @db.Decimal(12, 2)
  total             Decimal           @db.Decimal(12, 2)
  currency          String            @default("USD")
  items             PublicOrderItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([businessId, code])
  @@index([businessId, createdAt])
  @@index([businessId, status])
}

model PublicOrderItem {
  id            String      @id @default(cuid())
  publicOrderId String
  publicOrder   PublicOrder @relation(fields: [publicOrderId], references: [id], onDelete: Cascade)
  productId     String?
  name          String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(12, 2)
  subtotal      Decimal     @db.Decimal(12, 2)

  @@index([publicOrderId])
  @@index([productId])
}

model BusinessHardwareSettings {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ticketSize         String   @default("58")
  autoPrint          Boolean  @default(false)
  cashPrinterName    String?
  kitchenPrinterName String?
  openDrawerOnCash   Boolean  @default(false)
  copies             Int      @default(1)
  ticketLogoUrl      String?
  ticketFooter       String   @default("Gracias por su compra")
  scannerEnabled     Boolean  @default(true)
  customerDisplay    Boolean  @default(true)
  kioskMode          Boolean  @default(false)
  advancedHardware   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model User {
  id                 String           @id @default(cuid())
  clerkUserId        String           @unique
  businessId         String?
  business           Business?        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branches           UserBranch[]
  accessRoles        UserAccessRole[]
  fullName           String?
  email              String
  role               Role             @default(CASHIER)
  isActive           Boolean          @default(true)
  lastAccessAt       DateTime?
  sales              Sale[]
  openedCashSessions CashSession[]    @relation("CashSessionOpenedBy")
  closedCashSessions CashSession[]    @relation("CashSessionClosedBy")
  cashMovements      CashMovement[]
  stockTransfers     StockTransfer[]  @relation("StockTransferCreatedBy")
  preSales           PreSale[]        @relation("PreSaleCreatedBy")
  auditLogs          AuditLog[]
  productHistory     ProductHistory[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([businessId])
}

model AccessRole {
  id          String             @id @default(cuid())
  businessId  String
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  isSystem    Boolean            @default(false)
  permissions AccessPermission[]
  users       UserAccessRole[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
}

model AccessPermission {
  id        String     @id @default(cuid())
  roleId    String
  role      AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  section   String
  action    String
  createdAt DateTime   @default(now())

  @@unique([roleId, section, action])
  @@index([roleId])
}

model UserAccessRole {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model Branch {
  id             String            @id @default(cuid())
  businessId     String
  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  address        String?
  phone          String?
  currency       String            @default("USD")
  exchangeRate   Decimal           @default(1) @db.Decimal(12, 4)
  isMain         Boolean           @default(false)
  isActive       Boolean           @default(true)
  users          UserBranch[]
  inventory      BranchInventory[]
  sales          Sale[]
  cashSessions   CashSession[]
  cashMovements  CashMovement[]
  expenses       Expense[]
  transfersFrom  StockTransfer[]   @relation("TransferFromBranch")
  transfersTo    StockTransfer[]   @relation("TransferToBranch")
  preSales       PreSale[]
  auditLogs      AuditLog[]
  productHistory ProductHistory[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([businessId, slug])
  @@index([businessId, isActive])
}

model UserBranch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([branchId])
}

model Category {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Product {
  id                 String              @id @default(cuid())
  businessId         String
  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  imageUrl           String?
  categoryId         String?
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priceUsd           Decimal             @db.Decimal(12, 2)
  priceBs            Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  lowStockAlert      Int                 @default(5)
  sku                String?
  barcode            String?
  allowVariablePrice Boolean             @default(false)
  soldByWeight       Boolean             @default(false)
  unit               ProductUnit         @default(UNIT)
  isActive           Boolean             @default(true)
  isPublic           Boolean             @default(true)
  saleItems          SaleItem[]
  branchInventory    BranchInventory[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  stockTransferItems StockTransferItem[]
  preSaleItems       PreSaleItem[]
  history            ProductHistory[]

  @@unique([businessId, sku])
  @@index([businessId, isActive])
  @@index([businessId, categoryId])
  @@index([businessId, barcode])
  @@index([businessId])
}

model BranchInventory {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock         Decimal  @default(0) @db.Decimal(12, 3)
  lowStockAlert Decimal  @default(5) @db.Decimal(12, 3)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([branchId, productId])
  @@index([businessId, branchId])
  @@index([productId])
}

model Sale {
  id            String        @id @default(cuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  total         Decimal       @db.Decimal(12, 2)
  subtotal      Decimal       @db.Decimal(12, 2)
  currency      SaleCurrency  @default(USD)
  paymentMethod PaymentMethod
  kdsStatus     KdsStatus     @default(PENDING)
  cashierId     String
  cashier       User          @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  items         SaleItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, createdAt])
  @@index([cashierId])
}

model SaleItem {
  id              String  @id @default(cuid())
  saleId          String
  sale            Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  quantityDecimal Decimal @default(1) @db.Decimal(12, 3)
  unitPrice       Decimal @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
}

model CashSession {
  id               String            @id @default(cuid())
  businessId       String
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId         String?
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  openedById       String
  openedBy         User              @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById       String?
  closedBy         User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  openingAmountUsd Decimal           @db.Decimal(12, 2)
  openingAmountBs  Decimal           @db.Decimal(12, 2)
  closingAmountUsd Decimal?          @db.Decimal(12, 2)
  closingAmountBs  Decimal?          @db.Decimal(12, 2)
  expectedUsd      Decimal           @default(0) @db.Decimal(12, 2)
  expectedBs       Decimal           @default(0) @db.Decimal(12, 2)
  differenceUsd    Decimal           @default(0) @db.Decimal(12, 2)
  differenceBs     Decimal           @default(0) @db.Decimal(12, 2)
  status           CashSessionStatus @default(OPEN)
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  movements        CashMovement[]

  @@index([businessId, status])
  @@index([businessId, branchId, status])
  @@index([businessId, openedAt])
}

model CashMovement {
  id            String           @id @default(cuid())
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  cashSessionId String
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  type          CashMovementType
  amountUsd     Decimal          @default(0) @db.Decimal(12, 2)
  amountBs      Decimal          @default(0) @db.Decimal(12, 2)
  note          String?
  createdById   String
  createdBy     User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime         @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, branchId, createdAt])
  @@index([cashSessionId])
  @@index([createdById])
}

model Expense {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  description String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, branchId])
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model StockTransfer {
  id           String              @id @default(cuid())
  businessId   String
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromBranchId String
  fromBranch   Branch              @relation("TransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Restrict)
  toBranchId   String
  toBranch     Branch              @relation("TransferToBranch", fields: [toBranchId], references: [id], onDelete: Restrict)
  status       TransferStatus      @default(PENDING)
  notes        String?
  createdById  String
  createdBy    User                @relation("StockTransferCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items        StockTransferItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([businessId, status])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Decimal       @db.Decimal(12, 3)

  @@index([transferId])
  @@index([productId])
}

model PreSale {
  id          String        @id @default(cuid())
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdById String
  createdBy   User          @relation("PreSaleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  code        String
  status      PreSaleStatus @default(OPEN)
  notes       String?
  subtotalUsd Decimal       @default(0) @db.Decimal(12, 2)
  totalUsd    Decimal       @default(0) @db.Decimal(12, 2)
  expiresAt   DateTime
  paidSaleId  String?
  items       PreSaleItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([branchId, code])
  @@index([businessId, branchId, status])
}

model PreSaleItem {
  id           String  @id @default(cuid())
  preSaleId    String
  preSale      PreSale @relation(fields: [preSaleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity     Decimal @db.Decimal(12, 3)
  unitPriceUsd Decimal @db.Decimal(12, 2)
  subtotalUsd  Decimal @db.Decimal(12, 2)

  @@index([preSaleId])
  @@index([productId])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  module     String
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, module, createdAt])
  @@index([businessId, branchId, createdAt])
  @@index([userId, createdAt])
}

model ProductHistory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        String
  beforeValue Json?
  afterValue  Json?
  note        String?
  createdAt   DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, productId, createdAt])
  @@index([businessId, branchId, createdAt])
}
